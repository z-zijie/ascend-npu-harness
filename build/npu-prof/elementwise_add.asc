/**
 * elementwise_add.asc — AscendC vectorized elementwise add with msprof profiling
 * z[i] = x[i] + y[i]
 * Target arch: dav-2201 (Ascend 910B)
 */

#include <iostream>
#include <vector>
#include <algorithm>
#include <iterator>
#include <cmath>
#include "acl/acl.h"
#include "kernel_operator.h"

constexpr int32_t TOTAL_LENGTH = 256 * 1024;      // 256K elements
constexpr int32_t NUM_BLOCKS = 8;                  // 8 AI cores
constexpr int32_t BLOCK_LENGTH = TOTAL_LENGTH / NUM_BLOCKS;
constexpr int32_t TILE_NUM = 16;                   // 16 tiles per block for double-buffer
constexpr int32_t BUFFER_NUM = 2;
constexpr int32_t TILE_LENGTH = BLOCK_LENGTH / TILE_NUM / BUFFER_NUM;

// ============================================================================
// Vectorized AscendC Kernel — uses DataCopy (MTE2/MTE3) + VecAdd (Vector)
// ============================================================================
class KernelElementwiseAdd {
public:
    __aicore__ inline KernelElementwiseAdd() {}
    __aicore__ inline void Init(GM_ADDR x, GM_ADDR y, GM_ADDR z)
    {
        xGm.SetGlobalBuffer((__gm__ float *)x + BLOCK_LENGTH * AscendC::GetBlockIdx(), BLOCK_LENGTH);
        yGm.SetGlobalBuffer((__gm__ float *)y + BLOCK_LENGTH * AscendC::GetBlockIdx(), BLOCK_LENGTH);
        zGm.SetGlobalBuffer((__gm__ float *)z + BLOCK_LENGTH * AscendC::GetBlockIdx(), BLOCK_LENGTH);
    }

    __aicore__ inline void Process()
    {
        constexpr int32_t loopCount = TILE_NUM * BUFFER_NUM;
        // Ping-pong buffers in UB
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<float> xLocalPing = ubAllocator.Alloc<float, TILE_LENGTH>();
        AscendC::LocalTensor<float> yLocalPing = ubAllocator.Alloc<float, TILE_LENGTH>();
        AscendC::LocalTensor<float> zLocalPing = ubAllocator.Alloc<float, TILE_LENGTH>();
        AscendC::LocalTensor<float> xLocalPong = ubAllocator.Alloc<float, TILE_LENGTH>();
        AscendC::LocalTensor<float> yLocalPong = ubAllocator.Alloc<float, TILE_LENGTH>();
        AscendC::LocalTensor<float> zLocalPong = ubAllocator.Alloc<float, TILE_LENGTH>();

        // Hardware event synchronization for MTE<->Vector pipelining
        AscendC::SetFlag<AscendC::HardEvent::MTE3_MTE2>(EVENT_ID0);
        AscendC::SetFlag<AscendC::HardEvent::MTE3_MTE2>(EVENT_ID1);

        for (int32_t i = 0; i < loopCount; i++) {
            const int32_t eventId = (i % BUFFER_NUM == 0 ? EVENT_ID0 : EVENT_ID1);
            AscendC::LocalTensor<float> &xLocal = (i % BUFFER_NUM == 0 ? xLocalPing : xLocalPong);
            AscendC::LocalTensor<float> &yLocal = (i % BUFFER_NUM == 0 ? yLocalPing : yLocalPong);
            AscendC::LocalTensor<float> &zLocal = (i % BUFFER_NUM == 0 ? zLocalPing : zLocalPong);

            // MTE2/MTE3: GM -> UB copy
            AscendC::WaitFlag<AscendC::HardEvent::MTE3_MTE2>(eventId);
            AscendC::DataCopy(xLocal, xGm[i * TILE_LENGTH], TILE_LENGTH);
            AscendC::DataCopy(yLocal, yGm[i * TILE_LENGTH], TILE_LENGTH);

            // Vector: elementwise add on Vector Core
            AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(eventId);
            AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(eventId);
            AscendC::Add(zLocal, xLocal, yLocal, TILE_LENGTH);

            // MTE3: UB -> GM copy
            AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(eventId);
            AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(eventId);
            AscendC::DataCopy(zGm[i * TILE_LENGTH], zLocal, TILE_LENGTH);

            AscendC::SetFlag<AscendC::HardEvent::MTE3_MTE2>(eventId);
        }
        AscendC::WaitFlag<AscendC::HardEvent::MTE3_MTE2>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE3_MTE2>(EVENT_ID1);
    }

private:
    AscendC::GlobalTensor<float> xGm;
    AscendC::GlobalTensor<float> yGm;
    AscendC::GlobalTensor<float> zGm;
};

// ============================================================================
// Kernel entry — direct <<<>>> launch
// ============================================================================
__global__ __vector__ void elementwise_add_kernel(GM_ADDR x, GM_ADDR y, GM_ADDR z)
{
    AscendC::InitSocState();
    KernelElementwiseAdd op;
    op.Init(x, y, z);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

// ============================================================================
// Host-side launch — ACL runtime management
// ============================================================================
std::vector<float> launch_elementwise_add(std::vector<float> &x, std::vector<float> &y)
{
    constexpr uint32_t numBlocks = NUM_BLOCKS;
    uint32_t totalLength = x.size();
    size_t totalByteSize = totalLength * sizeof(float);
    int32_t deviceId = 0;
    aclrtStream stream = nullptr;
    uint8_t *xHost = reinterpret_cast<uint8_t *>(x.data());
    uint8_t *yHost = reinterpret_cast<uint8_t *>(y.data());
    uint8_t *zHost = nullptr;
    uint8_t *xDevice = nullptr;
    uint8_t *yDevice = nullptr;
    uint8_t *zDevice = nullptr;

    aclInit(nullptr);
    aclrtSetDevice(deviceId);
    aclrtCreateStream(&stream);

    aclrtMallocHost((void **)(&zHost), totalByteSize);
    aclrtMalloc((void **)&xDevice, totalByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void **)&yDevice, totalByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void **)&zDevice, totalByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    aclrtMemcpy(xDevice, totalByteSize, xHost, totalByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(yDevice, totalByteSize, yHost, totalByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    // Direct <<<>>> launch on NPU
    elementwise_add_kernel<<<numBlocks, nullptr, stream>>>(xDevice, yDevice, zDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, totalByteSize, zDevice, totalByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    std::vector<float> z((float *)zHost, (float *)(zHost + totalByteSize));

    aclrtFree(xDevice);
    aclrtFree(yDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(zHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return z;
}

// ============================================================================
// CPU Golden
// ============================================================================
void cpu_golden(const std::vector<float> &x, const std::vector<float> &y,
                std::vector<float> &golden)
{
    for (size_t i = 0; i < x.size(); ++i) {
        golden[i] = x[i] + y[i];
    }
}

// ============================================================================
// Accuracy verification
// ============================================================================
bool VerifyResult(std::vector<float> &output, std::vector<float> &golden)
{
    const float absTol = 1e-5f;
    const float relTol = 1e-5f;
    size_t mismatches = 0;
    float maxAbsErr = 0.0f;
    float maxRelErr = 0.0f;

    for (size_t i = 0; i < golden.size(); ++i) {
        float absErr = std::abs(output[i] - golden[i]);
        float relErr = 0.0f;
        if (std::abs(golden[i]) > 1e-12f) relErr = absErr / std::abs(golden[i]);
        else if (std::abs(output[i]) > 1e-12f) relErr = absErr / std::abs(output[i]);

        if (absErr > maxAbsErr) maxAbsErr = absErr;
        if (relErr > maxRelErr) maxRelErr = relErr;

        if (absErr > absTol && relErr > relTol) {
            mismatches++;
            if (mismatches <= 5) {
                std::cerr << "  Mismatch[" << i << "]: expected=" << golden[i]
                          << " actual=" << output[i]
                          << " absErr=" << absErr << " relErr=" << relErr << std::endl;
            }
        }
    }

    std::cout << "Accuracy: mismatches=" << mismatches << "/" << golden.size()
              << " maxAbsErr=" << maxAbsErr << " maxRelErr=" << maxRelErr << std::endl;

    if (mismatches == 0) {
        std::cout << "[PASS] elementwise_add accuracy verified." << std::endl;
        return true;
    } else {
        std::cout << "[FAIL] elementwise_add accuracy failed!" << std::endl;
        return false;
    }
}

// ============================================================================
// Main — run kernel and verify
// ============================================================================
int32_t main(int32_t argc, char *argv[])
{
    constexpr uint32_t totalLength = TOTAL_LENGTH;
    std::cout << "=== elementwise_add NPU Profiling ===" << std::endl;
    std::cout << "  totalLength=" << totalLength
              << " numBlocks=" << NUM_BLOCKS
              << " tileNum=" << TILE_NUM
              << " tileLength=" << TILE_LENGTH
              << " arch=dav-2201" << std::endl;

    // Generate test data
    std::vector<float> x(totalLength);
    std::vector<float> y(totalLength);
    for (uint32_t i = 0; i < totalLength; ++i) {
        x[i] = static_cast<float>(i) * 0.001f;
        y[i] = static_cast<float>(totalLength - i) * 0.001f;
    }

    // NPU execution
    std::cout << "\nLaunching NPU kernel..." << std::endl;
    std::vector<float> output = launch_elementwise_add(x, y);

    // CPU golden
    std::vector<float> golden(totalLength);
    cpu_golden(x, y, golden);

    // Verify
    return VerifyResult(output, golden) ? 0 : 1;
}
